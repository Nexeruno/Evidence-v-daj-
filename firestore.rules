rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper - kontrola admin role (admin + ml_admin)
    function isAdmin(uid) {
      return uid != null &&
        get(/databases/$(database)/documents/users/$(uid)).data.role in ['admin', 'ml_admin'];
    }

    // Helper - admin allow read (fallback)
    function isAdminCanRead(uid) {
      return uid != null &&
        (get(/databases/$(database)/documents/users/$(uid)).data.role in ['admin', 'ml_admin'] ||
         request.auth.token.admin == true);
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Uživatelé
    match /users/{uid} {
      // Read: sám sobě nebo admin
      allow read: if isOwner(uid) || isAdmin(request.auth.uid);
      // Write: sám sobě (ale ne role/disabled), admin může psát vše
      allow write: if isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'disabled'])
                   || isAdmin(request.auth.uid);

      // Transakce (vydaje, prijmy) — owner nebo admin/ml_admin
      match /vydaje/{document=**} {
        allow read: if isOwner(uid) || isAdmin(request.auth.uid);
        allow write: if isOwner(uid);
      }
      match /prijmy/{document=**} {
        allow read: if isOwner(uid) || isAdmin(request.auth.uid);
        allow write: if isOwner(uid);
      }

      // Opakující se transakce — owner nebo admin read
      match /repeatingTransactions/{document=**} {
        allow read: if isOwner(uid) || isAdmin(request.auth.uid);
        allow write: if isOwner(uid);
      }

      // Čekající transakce (pending) — owner nebo admin read
      match /pendingTransactions/{document=**} {
        allow read: if isOwner(uid) || isAdmin(request.auth.uid);
        allow write: if isOwner(uid);
      }

      // ML Predictions — user čte svoje predikce, admin vidí všechny, CF píše, user skrývá
      match /mlPredictions/{document=**} {
        allow read: if isOwner(uid) || isAdmin(request.auth.uid);
        allow write: if false;  // Jen Cloud Functions (Admin SDK)
        allow update: if isOwner(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hidden']);
      }

      // AI Profile — admin read, CF write
      match /aiProfile/{document=**} {
        allow read: if isOwner(uid) || isAdmin(request.auth.uid);
        allow write: if false;  // Jen Cloud Functions (Admin SDK)
      }
    }

    // Training Data — admin/ml_admin čte vše, CF píše
    match /trainingData/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions (Admin SDK)
    }

    // ML Debug Logs — admin čte, CF píše
    match /mlDebugLogs/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions (Admin SDK)
    }

    // ML Pipeline Status — admin čte, CF píše
    match /mlPipelineStatus/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions (Admin SDK)
    }

    // System Alerts (admin monitoring)
    match /systemAlerts/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }

    // System Repairs (auto-healing tracking)
    match /systemRepairs/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }

    // Usernames (pro ověření dostupnosti)
    match /usernames/{document=**} {
      allow read;
      allow write: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // AI DATA COLLECTIONS — Skryté uživatelům, přístupné jen adminovi + Cloud Functions
    // ═══════════════════════════════════════════════════════════════════════════════

    // Telemetry (user actions) — user píše, jen admin čte
    match /aiTelemetry/{uid}/{document=**} {
      allow create, write: if isOwner(uid);
      allow read, delete: if isAdmin(request.auth.uid);
    }

    // Full transaction data pro AI — jen admin má přístup (Cloud Functions)
    match /aiData/{uid}/{document=**} {
      allow read, write: if isAdmin(request.auth.uid);
    }

    // AI Insights — jen admin čte, CF píše (server)
    match /aiInsights/{uid} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions (Admin SDK)
    }

    // AI Configuration — jen admin
    match /aiConfig/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if isAdmin(request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // 🔒 SECURITY - Audit Logging (admin only)
    // ═══════════════════════════════════════════════════════════════════════════════

    // Audit Log — jen CF a admin
    match /_auditLog/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions
    }

    // Rate Limits — interní, nikdo nečte
    match /_rateLimits/{document=**} {
      allow read, write: if false;  // Jen Cloud Functions
    }

    // Security Events — jen CF píše, admin čte
    match /_securityEvents/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions
    }

    // Admin IP Log — jen CF píše, admin čte
    match /_adminIPLog/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // 🤖 ML PIPELINE - Run logs (predictions jsou v users/{uid}/mlPredictions)
    // ═══════════════════════════════════════════════════════════════════════════════

    // ML Run Logs — jen admin čte, CF píše
    match /mlRuns/{document=**} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false;  // Jen Cloud Functions (Admin SDK)
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // 🎛️ APP CONFIG - Prediction Settings (source of truth for Level 1/Level 2)
    // ═══════════════════════════════════════════════════════════════════════════════

    match /appConfig/{document=**} {
      allow read: if request.auth != null;  // All authenticated users can read config
      allow write: if isAdmin(request.auth.uid);  // Only admin can write
    }
  }
}
